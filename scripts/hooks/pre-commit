#!/usr/bin/env bash
# Pre-commit hook: run the new BG-scene regression tests before letting any
# commit through. These tests catch the most common ROM-side palette
# regressions (scene_detect dispatch wrong, banner_override/cutscene_override
# fill ranges wrong, splash table not loaded). Each test runs a headless
# mGBA in ~5s; total wall-clock ~15-20s for the 3 tests below.
#
# Install once with:
#   ln -sfn ../../scripts/hooks/pre-commit .git/hooks/pre-commit
#
# Skip with `git commit --no-verify` if you need to commit work-in-progress
# that you know will not pass yet.
#
# This intentionally does NOT run the full color_regression_tests.yaml suite
# (~18 OBJ tests) because of the well-known mGBA Lua "frame" callback timing
# issue that produces false positives on single-frame OAM reads. Once that's
# fixed (planned: scanline callback or busy-loop+retry), this hook can be
# expanded to the full suite.

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Detect whether the ROM-side build files were touched. If not, the regression
# tests have nothing new to validate — skip to keep the hook fast.
CHANGED=$(git diff --cached --name-only)
if ! echo "$CHANGED" | grep -qE 'scripts/(build_v301|bg_experiment|create_vblank|run_color)|tests/color_regression|palettes/.*\.yaml|rom/working/'; then
  echo "[pre-commit] No build/test/palette changes staged — skipping regression suite."
  exit 0
fi

ROM="rom/working/penta_dragon_dx_teleport.gb"
if [[ ! -f "$ROM" ]]; then
  echo "[pre-commit] $ROM missing — building..."
  uv run python scripts/build_v301_teleport.py > /tmp/precommit_build.log 2>&1 \
    || { echo "[pre-commit] BUILD FAILED — see /tmp/precommit_build.log"; exit 1; }
fi

echo "[pre-commit] Running regression tests against $ROM..."
# Tests selected for the hook are the ones VERIFIED to pass reliably on the
# current wip-color-sweep build. Tests that fail due to pre-existing test-
# data issues (e.g., gargoyle YAML says "expected pal7 but intended pal6")
# are intentionally excluded until the YAML is corrected. The consensus
# OAM filter (commit 457cc73) lets us include sara_w_alone in the hook —
# it was failing before due to the Lua frame-callback timing artifact.
TESTS=(
  # BG scene-dispatch tests (verify scene_detect routes the right D880 to the
  # right bg_table + per-scene overrides patch 0xDA00 correctly):
  banner_bg_table_palettes
  cutscene_bg_table_palettes
  splash_bg_table_all_pal0
  postboss_reload_bg_table_all_pal0
  miniboss_uses_dungeon_table
  dungeon_uses_dungeon_table
  # Iter 16: hazard + wall + item bg_table regression tests. These verify
  # the dungeon table maps spike tiles (0x2A-0x2E, 0x3A-0x3D) to pal 6
  # (metallic, not lava), wall corners (0x47/0x57 etc.) to pal 6 (not the
  # 2026-05-23 orange regression), and items+font (0x80-0xDF) to pal 1
  # (uniform red). Catches anyone who reverts _bg_table() in build_v301_gdma.
  dungeon_table_spikes_metallic
  dungeon_table_wall_corners
  dungeon_table_items_and_font
  # Iter 17: stage-5/7 LAVA override + FFBA guard regression. Verifies the
  # build_lava_override at bank13:0x7E00 patches molten tile IDs to pal 5
  # when FFBA = 4 or 6, AND that the FFBA guard prevents the override from
  # leaking into stage 1 (FFBA=0). Catches anyone who disables the per-frame
  # CALL, breaks the FFBA dispatch, or weakens the guard.
  lava_stage5_override
  lava_stage7_override
  lava_off_at_ffba0
  # Iter 18: per-arena bg_table CONTENT tests. The *_arena_dispatch tests
  # only check "tile 0x00 = pal 0" (catches off-by-one in dispatch math
  # but NOT arena-table corruption). These verify signature tile→palette
  # mappings unique to each boss arena (e.g. Shalamar crown 0x11 → pal 4
  # cyan, Penta Dragon red head 0x48 → pal 5). Together with the dispatch
  # tests, they pin down both the routing AND the contents.
  shalamar_arena_content
  riff_arena_content
  crystal_dragon_arena_content
  cameo_arena_content
  ted_arena_content
  troop_arena_content
  faze_arena_content
  angela_arena_content
  penta_dragon_arena_content
  # All 9 boss arena dispatches (D880 = 0x0C..0x14):
  shalamar_arena_dispatch
  riff_arena_dispatch
  crystal_dragon_arena_dispatch
  cameo_arena_dispatch
  ted_arena_dispatch
  troop_arena_dispatch
  faze_arena_dispatch
  angela_arena_dispatch
  penta_dragon_arena_dispatch
  # OBJ tests (all verified reliable on wip-color-sweep via consensus filter):
  sara_w_alone
  sara_d_alone
  crow
  sara_d_hornet_or_moth
  jet_form_secret_stage
  spiral_power_active
  # Iter 10: WRAM STAT-IRQ stub (be7d5e3 + this) fixes Sara slot-1
  # alternation in boss fights, unlocking these previously-flaky tests:
  moth
  gargoyle_miniboss
)
FAILED=()
for t in "${TESTS[@]}"; do
  if ! QT_QPA_PLATFORM=offscreen SDL_AUDIODRIVER=dummy xvfb-run -a \
       uv run python scripts/run_color_regression.py --rom "$ROM" --test "$t" \
       > "/tmp/precommit_${t}.log" 2>&1; then
    FAILED+=("$t")
    echo "  [FAIL] $t — see /tmp/precommit_${t}.log"
  else
    echo "  [PASS] $t"
  fi
done

if [[ ${#FAILED[@]} -gt 0 ]]; then
  echo
  echo "[pre-commit] ${#FAILED[@]} regression test(s) failed — blocking commit."
  echo "[pre-commit] To override (e.g., for WIP), use: git commit --no-verify"
  exit 1
fi

echo "[pre-commit] All BG-scene regression tests passed."
exit 0
